Before:
  let g:toas_transport_mode = 'local_host'
  let g:_toas_cancel_escalation_calls = 0

  function! g:ToasLocalHostCancelEscalationRequest(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rescalate123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      let g:_toas_cancel_escalation_calls += 1
      if g:_toas_cancel_escalation_calls == 1
        return {'ok': v:true, 'payload': {'run_id': 'rescalate123', 'status': 'cancelling'}}
      endif
      return {
            \ 'ok': v:true,
            \ 'payload': {
            \   'run_id': 'rescalate123',
            \   'status': 'cancelled',
            \   'forced': v:true,
            \   'error': 'cancel escalated by operator; forced termination',
            \ },
            \ }
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'status': 'cancelled', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op: ' . a:op
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostCancelEscalationRequest')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasLocalHostCancelEscalationRequest
  unlet! g:_toas_cancel_escalation_calls
  unlet! g:toas_transport_mode

Execute (local_host ToasCancel should surface cancelling and immediate forced terminal escalation):
  let g:toas_test_session = tempname() . '.md'
  execute 'edit ' . fnameescape(g:toas_test_session)
  call setline(1, ['## TOAS:USER', '', 'hello'])
  write
  call ToasStep()
  call ToasCancel('rescalate123')
  Assert search('^status: cancelling\>', 'nw') > 0
  call ToasCancel('rescalate123')

Then:
  Assert get(g:, '_toas_cancel_escalation_calls', 0) == 2
  Assert get(g:, 'toas_last_run_status', '') ==# 'cancelled'
  Assert search('^status: cancelled\>', 'nw') > 0
  Assert search('\V[run cancelled] cancel escalated by operator; forced termination', 'nw') > 0
