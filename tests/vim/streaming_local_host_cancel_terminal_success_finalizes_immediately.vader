Before:
  let g:toas_transport_mode = 'local_host'
  let g:_toas_cancel_success_watch_calls = 0

  function! g:ToasLocalHostCancelSuccessRequest(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rsuccess123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      return {'ok': v:true, 'payload': {'run_id': 'rsuccess123', 'status': 'succeeded'}}
    endif
    if a:op ==# 'watch'
      let g:_toas_cancel_success_watch_calls += 1
      return {
            \ 'ok': v:true,
            \ 'payload': {
            \   'run_id': 'rsuccess123',
            \   'status': 'succeeded',
            \   'chunk': "## TOAS:ASSISTANT\n\nhello from final projection\n",
            \   'next_offset': 45,
            \   'next_seq': 1,
            \   'events': [],
            \ },
            \ }
    endif
    throw 'unexpected op: ' . a:op
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostCancelSuccessRequest')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasLocalHostCancelSuccessRequest
  unlet! g:_toas_cancel_success_watch_calls
  unlet! g:toas_transport_mode

Execute (local_host ToasCancel should immediately finalize a succeeded run region):
  let g:toas_test_session = tempname() . '.md'
  execute 'edit ' . fnameescape(g:toas_test_session)
  call setline(1, ['## TOAS:USER', '', 'hello'])
  write
  call ToasStep()
  let g:run_start = search('^## TOAS:RUN rsuccess123$', 'nw')
  let g:run_end = search('^## /TOAS:RUN rsuccess123$', 'nw')
  call setline(g:run_start, ['## TOAS:RUN rsuccess123', 'status: cancelling 0:03', '## TOAS:ASSISTANT', '```yaml', 'operation: shell', 'arguments:', '', '## /TOAS:RUN rsuccess123'])
  if g:run_end > g:run_start + 7
    execute (g:run_start + 8) . ',' . g:run_end . 'delete _'
  endif
  call ToasCancel('rsuccess123')

Then:
  Assert get(g:, 'toas_last_run_status', '') ==# 'succeeded'
  Assert get(g:, '_toas_cancel_success_watch_calls', 0) == 1
  Assert search('^## TOAS:ASSISTANT$', 'nw') > 0
  Assert search('hello from final projection', 'nw') > 0
  Assert search('^## TOAS:RUN rsuccess123$', 'nw') == 0
  Assert search('^status: succeeded\>', 'nw') == 0
