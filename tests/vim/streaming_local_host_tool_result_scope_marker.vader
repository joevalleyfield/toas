Before:
  set nocompatible
  set hidden
  source vim/plugin/toas.vim
  let g:toas_step_nonblocking = 1
  let g:toas_notice_enabled = 0
  let g:toas_transport_mode = 'local_host'
  let g:toas_step_lane_order = ['default']

  function! g:ToasLocalHostToolResultScopeMarker(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rtoolscope1', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'status': 'running', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op=' . a:op
  endfunction

  function! g:ToasLocalHostToolResultScopeMarkerFrames(run_id, timeout_s) abort
    return [
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_ack', 'run_id': a:run_id}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'llm_delta', 'seq': 1, 'payload': {'text': "## RESULT\n\n[OK] shell: exit=0\nstdout:\n/workspace\n"}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'llm_done', 'seq': 2, 'payload': {'status': 'succeeded'}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_complete', 'run_id': a:run_id, 'complete': v:true}},
          \ ]
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostToolResultScopeMarker')
  let g:ToasTestLocalHostSubscribeFn = function('g:ToasLocalHostToolResultScopeMarkerFrames')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasTestLocalHostSubscribeFn
  unlet! g:ToasLocalHostToolResultScopeMarker
  unlet! g:ToasLocalHostToolResultScopeMarkerFrames
  unlet! g:toas_transport_mode
  let g:toas_step_lane_order = ['default', 'warm', 'cold', 'synchronous']

Execute (local_host stream completion should preserve user scope marker before RESULT projection):
  call setline(1, ['# local host tool result scope marker'])
  call ToasStepAsync()
  Assert get(g:, 'toas_active_run_id', '') ==# 'rtoolscope1'
  call ToasWatch('rtoolscope1', '--follow')
  let g:tool_scope_text = join(getline(1, '$'), "\n")
  Assert g:tool_scope_text =~# '## TOAS:USER'
  Assert g:tool_scope_text =~# '## RESULT'
  Assert g:tool_scope_text =~# '\[OK\] shell: exit=0'
