Before:
  set nocompatible
  set hidden
  source vim/plugin/toas.vim
  let g:toas_step_nonblocking = 1
  let g:toas_notice_enabled = 0
  let g:toas_transport_mode = 'local_host'
  let g:toas_step_lane_order = ['default']
  let g:toas_stream_policy_resubscribe_calls = 0

  function! g:ToasLocalHostStreamPolicyPersistRequest(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rpolicy1', 'status': 'running', 'stream_policy': {'thinking': v:true, 'prompt_progress': v:true}}}
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'status': 'running', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op=' . a:op
  endfunction

  function! g:ToasLocalHostStreamPolicyPersistFrames(run_id, timeout_s) abort
    let g:toas_stream_policy_resubscribe_calls += 1
    if g:toas_stream_policy_resubscribe_calls == 1
      return [
            \ {'ok': v:true, 'request_id': 'sub-p1', 'payload': {'kind': 'push_ack', 'run_id': a:run_id}},
            \ {'ok': v:true, 'request_id': 'sub-p1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'llm_delta', 'lane': 'llm_answer', 'phase': 'delta', 'seq': 1, 'payload': {'text': "one-"}}}},
            \ {'ok': v:true, 'request_id': 'sub-p1', 'payload': {'kind': 'push_complete', 'run_id': a:run_id, 'complete': v:false}},
            \ ]
    endif
    return [
          \ {'ok': v:true, 'request_id': 'sub-p2', 'payload': {'kind': 'push_ack', 'run_id': a:run_id}},
          \ {'ok': v:true, 'request_id': 'sub-p2', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'llm_delta', 'lane': 'llm_answer', 'phase': 'delta', 'seq': 2, 'payload': {'text': "two"}}}},
          \ {'ok': v:true, 'request_id': 'sub-p2', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'run_done', 'lane': 'run', 'phase': 'end', 'seq': 3, 'payload': {'status': 'succeeded'}}}},
          \ {'ok': v:true, 'request_id': 'sub-p2', 'payload': {'kind': 'push_complete', 'run_id': a:run_id, 'complete': v:true}},
          \ ]
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostStreamPolicyPersistRequest')
  let g:ToasTestLocalHostSubscribeFn = function('g:ToasLocalHostStreamPolicyPersistFrames')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasTestLocalHostSubscribeFn
  unlet! g:ToasLocalHostStreamPolicyPersistRequest
  unlet! g:ToasLocalHostStreamPolicyPersistFrames
  unlet! g:toas_stream_policy_resubscribe_calls
  unlet! g:toas_transport_mode
  let g:toas_step_lane_order = ['default', 'warm', 'cold', 'synchronous']

Execute (local_host resubscribe should preserve acknowledged stream policy):
  call setline(1, ['## TOAS:USER', '', '# local host policy persistence'])
  call ToasStepAsync()
  Assert get(g:, 'toas_active_run_id', '') ==# 'rpolicy1'
  call ToasWatch('rpolicy1', '--follow')
  let g:policy_persist_text = join(getline(1, '$'), "\n")
  Assert g:policy_persist_text =~# 'stream: thinking=on prompt_progress=on'
  Assert g:policy_persist_text =~# 'one-two'
