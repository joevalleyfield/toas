Before:
  set nocompatible
  let g:toas_step_nonblocking = 1
  let g:toas_workdir = getcwd()
  let g:toas_notice_enabled = 0
  let g:_toas_cancel_cmd_watch_i = 0
  let g:_toas_cancel_cmd_cancel_calls = 0

  function! g:ToasCancelCommandParityRpc(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'payload': {'run_id': 'rcmd123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      let g:_toas_cancel_cmd_cancel_calls += 1
      return {'payload': {'run_id': 'rcmd123', 'status': 'cancelling'}}
    endif
    if a:op ==# 'watch'
      let g:_toas_cancel_cmd_watch_i += 1
      if g:_toas_cancel_cmd_watch_i == 1
        return {'payload': {'status': 'cancelling', 'chunk': '', 'next_offset': 0, 'next_seq': 1, 'events': []}}
      endif
      return {'payload': {'status': 'cancelled', 'chunk': '', 'error': 'cancel timed out; forced termination', 'next_offset': 0, 'next_seq': 2, 'events': []}}
    endif
    throw 'unexpected op: ' . a:op
  endfunction

  let g:ToasTestRpcRequestFn = function('g:ToasCancelCommandParityRpc')

After:
  unlet! g:ToasTestRpcRequestFn
  unlet! g:ToasCancelCommandParityRpc
  unlet! g:_toas_cancel_cmd_watch_i
  unlet! g:_toas_cancel_cmd_cancel_calls

Execute (ToasCancel should request cancel and converge watch to terminal):
  let g:toas_test_session = tempname() . '.md'
  execute 'edit ' . fnameescape(g:toas_test_session)
  call setline(1, ['## TOAS:USER', '', 'hello'])
  write
  call ToasStepAsync()
  call ToasCancel('rcmd123')
  call ToasWatch('rcmd123', '--follow')

Then:
  Assert get(g:, '_toas_cancel_cmd_cancel_calls', 0) == 1
  Assert get(g:, 'toas_last_run_status', '') ==# 'cancelled'
