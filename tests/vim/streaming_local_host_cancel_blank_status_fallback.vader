Before:
  let g:toas_transport_mode = 'local_host'

  function! g:ToasLocalHostCancelBlankStatusRequest(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rblank123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      if get(g:, '_toas_cancel_blank_status_calls', 0) == 0
        let g:_toas_cancel_blank_status_calls = 1
        return {'ok': v:true, 'payload': {'run_id': 'rblank123', 'status': 'cancelling'}}
      endif
      return {'ok': v:true, 'payload': {'run_id': 'rblank123'}}
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'run_id': 'rblank123', 'status': 'running', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op: ' . a:op
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostCancelBlankStatusRequest')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasLocalHostCancelBlankStatusRequest
  unlet! g:_toas_cancel_blank_status_calls
  unlet! g:toas_transport_mode

Execute (local_host ToasCancel should keep prior status when cancel response omits status):
  let g:toas_test_session = tempname() . '.md'
  execute 'edit ' . fnameescape(g:toas_test_session)
  call setline(1, ['## TOAS:USER', '', 'hello'])
  write
  call ToasStep()
  call ToasCancel('rblank123')
  Assert search('^status: cancelling\>', 'nw') > 0
  call ToasCancel('rblank123')

Then:
  Assert get(g:, 'toas_last_run_status', '') ==# 'cancelling'
  Assert search('^status: cancelling\>', 'nw') > 0
  Assert search('^status: $', 'nw') == 0
