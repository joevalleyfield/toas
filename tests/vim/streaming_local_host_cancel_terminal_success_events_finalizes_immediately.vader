Before:
  let g:toas_transport_mode = 'local_host'
  let g:_toas_cancel_success_events_watch_calls = 0

  function! g:ToasLocalHostCancelSuccessEventsRequest(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rsuccessevents123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      return {'ok': v:true, 'payload': {'run_id': 'rsuccessevents123', 'status': 'succeeded'}}
    endif
    if a:op ==# 'watch'
      let g:_toas_cancel_success_events_watch_calls += 1
      return {
            \ 'ok': v:true,
            \ 'payload': {
            \   'run_id': 'rsuccessevents123',
            \   'status': 'succeeded',
            \   'chunk': '',
            \   'next_offset': 0,
            \   'next_seq': 3,
            \   'events': [
            \     {'type': 'llm_delta', 'lane': 'llm_answer', 'phase': 'delta', 'seq': 1, 'payload': {'text': '## TOAS:ASSISTANT'}},
            \     {'type': 'llm_delta', 'lane': 'llm_answer', 'phase': 'delta', 'seq': 2, 'payload': {'text': "\n\nhello from semantic final events\n"}},
            \     {'type': 'llm_done', 'lane': 'llm_answer', 'phase': 'end', 'seq': 3, 'payload': {'status': 'succeeded'}},
            \   ],
            \ },
            \ }
    endif
    throw 'unexpected op: ' . a:op
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostCancelSuccessEventsRequest')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasLocalHostCancelSuccessEventsRequest
  unlet! g:_toas_cancel_success_events_watch_calls
  unlet! g:toas_transport_mode

Execute (local_host ToasCancel should immediately finalize a succeeded run region from semantic events even when chunk is empty):
  let g:toas_test_session = tempname() . '.md'
  execute 'edit ' . fnameescape(g:toas_test_session)
  call setline(1, ['## TOAS:USER', '', 'hello'])
  write
  call ToasStep()
  let g:run_start = search('^## TOAS:RUN rsuccessevents123$', 'nw')
  let g:run_end = search('^## /TOAS:RUN rsuccessevents123$', 'nw')
  call setline(g:run_start, ['## TOAS:RUN rsuccessevents123', 'status: cancelling 0:03', '## TOAS:ASSISTANT', '```yaml', 'operation: shell', 'arguments:', '', '## /TOAS:RUN rsuccessevents123'])
  if g:run_end > g:run_start + 7
    execute (g:run_start + 8) . ',' . g:run_end . 'delete _'
  endif
  call ToasCancel('rsuccessevents123')

Then:
  Assert get(g:, 'toas_last_run_status', '') ==# 'succeeded'
  Assert get(g:, '_toas_cancel_success_events_watch_calls', 0) == 1
  Assert search('^## TOAS:ASSISTANT$', 'nw') > 0
  Assert search('hello from semantic final events', 'nw') > 0
  Assert search('^## TOAS:RUN rsuccessevents123$', 'nw') == 0
  Assert search('^status: succeeded\>', 'nw') == 0
