Before:
  set nocompatible
  set hidden
  source vim/plugin/toas.vim
  let g:toas_step_nonblocking = 1
  let g:toas_notice_enabled = 0
  let g:toas_transport_mode = 'local_host'
  let g:toas_step_lane_order = ['default']

  function! g:ToasLocalHostToolLaneFinalScope(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rtoolfinal1', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'status': 'running', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op=' . a:op
  endfunction

  function! g:ToasLocalHostToolLaneFinalScopeFrames(run_id, timeout_s) abort
    return [
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_ack', 'run_id': a:run_id}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'tool_progress', 'lane': 'tool', 'phase': 'delta', 'seq': 1, 'payload': {'text': "line one\nline two\n"}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'type': 'tool_done', 'lane': 'tool', 'phase': 'end', 'seq': 2, 'payload': {'operation': 'shell', 'ok': v:true}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_complete', 'run_id': a:run_id, 'complete': v:true}},
          \ ]
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostToolLaneFinalScope')
  let g:ToasTestLocalHostSubscribeFn = function('g:ToasLocalHostToolLaneFinalScopeFrames')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasTestLocalHostSubscribeFn
  unlet! g:ToasLocalHostToolLaneFinalScope
  unlet! g:ToasLocalHostToolLaneFinalScopeFrames
  unlet! g:toas_transport_mode
  let g:toas_step_lane_order = ['default', 'warm', 'cold', 'synchronous']

Execute (tool lane completion should not be finalized as assistant projection):
  call setline(1, ['## TOAS:USER', '', '# local host tool lane final scope'])
  call ToasStepAsync()
  Assert get(g:, 'toas_active_run_id', '') ==# 'rtoolfinal1'
  call ToasWatch('rtoolfinal1', '--follow')
  let g:tool_final_text = join(getline(1, '$'), "\n")
  Assert g:tool_final_text =~# '## TOAS:USER'
  Assert g:tool_final_text =~# 'line one'
  Assert g:tool_final_text !~# '## TOAS:ASSISTANT'
