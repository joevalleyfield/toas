Before:
  let g:toas_transport_mode = 'local_host'

  function! g:ToasLocalHostSubscribeParity(op, payload, timeout_s) abort
    if a:op ==# 'step_async'
      return {'ok': v:true, 'payload': {'run_id': 'rsub123', 'status': 'running', 'stream_policy': {}}}
    endif
    if a:op ==# 'cancel'
      return {'ok': v:true, 'payload': {'run_id': 'rsub123', 'status': 'cancelling'}}
    endif
    if a:op ==# 'watch'
      return {'ok': v:true, 'payload': {'status': 'running', 'chunk': '', 'next_offset': 0, 'next_seq': 0, 'events': []}}
    endif
    throw 'unexpected op=' . a:op
  endfunction

  function! g:ToasLocalHostSubscribeFrames(run_id, timeout_s) abort
    return [
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_ack', 'run_id': a:run_id}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'lane': 'llm_answer', 'phase': 'delta', 'seq': 1, 'payload': {'text': "hello"}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_event', 'run_id': a:run_id, 'event': {'lane': 'llm_answer', 'phase': 'end', 'seq': 2, 'payload': {'status': 'succeeded'}}}},
          \ {'ok': v:true, 'request_id': 'sub-1', 'payload': {'kind': 'push_complete', 'run_id': a:run_id, 'complete': v:true}},
          \ ]
  endfunction

  let g:ToasTestLocalHostRequestFn = function('g:ToasLocalHostSubscribeParity')
  let g:ToasTestLocalHostSubscribeFn = function('g:ToasLocalHostSubscribeFrames')

After:
  unlet! g:ToasTestLocalHostRequestFn
  unlet! g:ToasTestLocalHostSubscribeFn
  unlet! g:ToasLocalHostSubscribeParity
  unlet! g:ToasLocalHostSubscribeFrames
  unlet! g:toas_transport_mode

Execute (local_host follow watch should consume push subscribe frames):
  call setline(1, ['# local host subscribe'])
  call ToasStepAsync()
  Assert get(g:, 'toas_active_run_id', '') ==# 'rsub123'
  call ToasWatch('rsub123', '--follow')
  Assert join(getline(1, '$'), "\n") =~# 'hello'
  Assert get(g:, 'toas_last_run_status', '') ==# 'succeeded'
